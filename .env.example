# =============================================================================
# The Estate Steward — Environment Configuration Template
# Copy to .env and fill in values before running docker-compose up
# =============================================================================

# --- Database ---
DB_URL=postgresql+psycopg2://user:pass@db:5432/estate
ENCRYPTION_KEY=                          # REQUIRED: 43-char base64 Fernet key. Generate with:
                                          #   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- LLM Provider Configuration ---
LLM_PROVIDER=ollama                       # ollama | openai | anthropic | google
EMBEDDING_PROVIDER=ollama                 # ollama | openai | google
VISION_PROVIDER=ollama                    # ollama | openai | google | anthropic

# --- Ollama (Local) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
FAST_THINKER_MODEL=qwen2.5:latest
SLOW_THINKER_MODEL=qwen2.5:14b
VISION_MODEL=llava:latest
EMBEDDING_MODEL=nomic-embed-text

# --- OpenAI (Optional — set LLM_PROVIDER=openai to activate) ---
OPENAI_API_KEY=
# FAST_THINKER_MODEL=gpt-4o-mini
# SLOW_THINKER_MODEL=gpt-4o
# VISION_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic (Optional — set LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
# FAST_THINKER_MODEL=claude-3-5-haiku-latest
# SLOW_THINKER_MODEL=claude-3-5-sonnet-latest
# VISION_MODEL=claude-3-5-sonnet-latest

# --- Google Gemini (Optional — set LLM_PROVIDER=google) ---
GEMINI_API_KEY=
# FAST_THINKER_MODEL=gemini-2.0-flash
# SLOW_THINKER_MODEL=gemini-2.0-pro
# VISION_MODEL=gemini-2.0-flash
# EMBEDDING_MODEL=text-embedding-004

# --- Kokoro TTS Model Paths ---
KOKORO_MODEL_PATH=app/models/kokoro-v0.19.onnx
KOKORO_VOICES_PATH=app/models/voices.json

# --- SMTP (Email Delivery) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=executor@example.com
SMTP_PASSWORD=                             # App-specific password for Gmail, or SMTP relay credential
SMTP_FROM=keepsakes@estate-steward.org

# --- Storage Driver ---
STORAGE_DRIVER=LOCAL                       # LOCAL | GCS
GCS_BUCKET_NAME=                           # Required only if STORAGE_DRIVER=GCS

# --- Observability (Langfuse / Langtrace) ---
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=http://langfuse:3000         # Points to docker-compose langfuse service
LANGTRACE_API_KEY=                         # Optional: OpenTelemetry tracing via Langtrace

# --- Logging & Debugging ---
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
DB_ECHO=false                              # true | false — prints all SQL queries when true