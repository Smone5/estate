# =============================================================================
# The Estate Steward — Environment Configuration Template
# Copy to .env and fill in values before running docker-compose up
# =============================================================================
#
# QUICK GUIDE: LOCAL vs PRODUCTION
# ---------------------------------
# Local (Docker Compose, same machine):
#   - PUBLIC_BASE_URL can be left blank; the app derives it from the request.
#   - SMTP can point to the bundled Mailpit service (emails captured locally).
#   - STORAGE_DRIVER=LOCAL is fine.
#
# Production (Cloud / internet-accessible):
#   - PUBLIC_BASE_URL=https://yourdomain.com  ← REQUIRED for invite links to work
#   - SMTP_* must point to a real provider (Gmail, SendGrid, Postmark, etc.)
#   - STORAGE_DRIVER=S3 or GCS recommended for persistent file storage
#   - JWT_SECRET and ENCRYPTION_KEY must be strong random values (see below)
#   - Cloudflare Tunnel or an HTTPS reverse proxy is strongly recommended
#
# =============================================================================

# --- Database ---
DB_URL=postgresql+psycopg2://user:pass@db:5432/estate

# REQUIRED: 43-char base64 Fernet key used to encrypt uploaded ID documents.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# REQUIRED in production: Strong random secret for JWT session tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=dev-jwt-secret-change-in-production

# --- Public URL (Critical for Production) ---
# The full public URL where the app is hosted, with no trailing slash.
# Used to generate heir invitation links in emails.
# Leave blank in local development (the app will derive it from the request host).
# Example: https://estate.yourdomain.com
# Required (paired with CLOUDFLARE_TUNNEL_TOKEN below) for mobile/PWA testing
# over real HTTPS — see docs/cloudflare-tunnel-setup.md
PUBLIC_BASE_URL=

# --- LLM Provider Configuration ---
LLM_PROVIDER=ollama                       # ollama | openai | anthropic | google | openrouter | nvidia
EMBEDDING_PROVIDER=ollama                 # ollama | openai | google | openrouter | nvidia
VISION_PROVIDER=ollama                    # ollama | openai | google | anthropic | openrouter | nvidia

# --- Ollama (Local, default) ---
# For cloud deployments, switch LLM_PROVIDER to openai, anthropic, or google
# and set the corresponding API key below.
OLLAMA_BASE_URL=http://host.docker.internal:11434
FAST_THINKER_MODEL=qwen2.5:latest
SLOW_THINKER_MODEL=qwen2.5:14b
VISION_MODEL=llava:latest
EMBEDDING_MODEL=nomic-embed-text

# --- OpenAI (Optional — set LLM_PROVIDER=openai to activate) ---
OPENAI_API_KEY=
# FAST_THINKER_MODEL=gpt-4o-mini
# SLOW_THINKER_MODEL=gpt-4o
# VISION_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic (Optional — set LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
# FAST_THINKER_MODEL=claude-3-5-haiku-latest
# SLOW_THINKER_MODEL=claude-3-5-sonnet-latest
# VISION_MODEL=claude-3-5-sonnet-latest

# --- Google Gemini (Optional — set LLM_PROVIDER=google) ---
GEMINI_API_KEY=
# FAST_THINKER_MODEL=gemini-2.0-flash
# SLOW_THINKER_MODEL=gemini-2.0-pro
# VISION_MODEL=gemini-2.0-flash
# EMBEDDING_MODEL=text-embedding-004

# --- OpenRouter (Optional — set LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# FAST_THINKER_MODEL=openai/gpt-4o-mini
# SLOW_THINKER_MODEL=anthropic/claude-3.5-sonnet
# VISION_MODEL=openai/gpt-4o-mini
# EMBEDDING_MODEL=openai/text-embedding-3-small

# --- NVIDIA NIM (Optional — set LLM_PROVIDER=nvidia) ---
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# FAST_THINKER_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# SLOW_THINKER_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# VISION_MODEL=nvidia/neva-22b
# EMBEDDING_MODEL=nvidia/nv-embed-qa-4

# --- Kokoro TTS Model Paths ---
KOKORO_MODEL_PATH=app/models/kokoro-v1.0.onnx
KOKORO_VOICES_PATH=app/models/voices-v1.0.bin

# --- SMTP (Email Delivery) ---
# LOCAL DEVELOPMENT (default):
#   Uses the bundled Mailpit service. Emails are captured at http://localhost:8025.
#   No real emails are sent.
#
# PRODUCTION:
#   Replace with real SMTP credentials. Common providers:
#   - Gmail:    SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USE_TLS=true
#   - SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USE_TLS=true  SMTP_USERNAME=apikey
#   - Postmark: SMTP_HOST=smtp.postmarkapp.com  SMTP_PORT=587  SMTP_USE_TLS=true
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_SENDER=estate-steward@localhost

# --- Storage Driver ---
# LOCAL: Files stored on the server filesystem (default, good for local/Raspberry Pi)
# S3:    Files stored in AWS S3 or S3-compatible storage (recommended for cloud)
# GCS:   Files stored in Google Cloud Storage
STORAGE_DRIVER=LOCAL
GCS_BUCKET_NAME=                           # Required only if STORAGE_DRIVER=GCS
S3_BUCKET_NAME=                            # Required only if STORAGE_DRIVER=S3
S3_ENDPOINT_URL=                           # Optional: Custom endpoint URL (e.g. http://localhost:9000 for MinIO)
AWS_ACCESS_KEY_ID=                         # Required if STORAGE_DRIVER=S3
AWS_SECRET_ACCESS_KEY=                     # Required if STORAGE_DRIVER=S3
AWS_REGION_NAME=                           # Optional: S3 region name

# --- Observability (Langfuse / Langtrace) ---
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=http://langfuse:3000         # Points to docker-compose langfuse service
LANGTRACE_API_KEY=                         # Optional: OpenTelemetry tracing via Langtrace

# --- Cloudflare Tunnel (Secure Public Exposure, No Open Ports) ---
# Recommended for exposing a locally-hosted instance to the internet without
# configuring port forwarding or a reverse proxy. Required for full mobile
# testing (voice recording needs real HTTPS) — see docs/cloudflare-tunnel-setup.md
# for the full walkthrough (creating the tunnel, getting a domain, etc.).
# Setup: https://one.dash.cloudflare.com → Networks → Tunnels → Create Tunnel
# Launch: docker compose --profile tunnel up -d
# Pair this with PUBLIC_BASE_URL above, set to the hostname you configure in
# the tunnel's "Add a public hostname" / "Routes" step.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Logging & Debugging ---
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
DB_ECHO=false                              # true | false — prints all SQL queries when true

# --- Logging & Debugging ---
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
DB_ECHO=false                              # true | false — prints all SQL queries when true
